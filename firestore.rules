rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Solo el admin autenticado puede leer y escribir las API keys
    match /apiKeys/{keyId} {
      allow read, write: if request.auth != null
                         && request.auth.token.email_verified == true
                         && request.auth.token.email == 'santiagoeduardo331@gmail.com';
    }

    // Logs de acceso: solo el admin puede leer, nadie escribe desde el cliente
    match /accessLogs/{logId} {
      allow read: if request.auth != null
                  && request.auth.token.email == 'santiagoeduardo331@gmail.com';
      allow write: if false;
    }

    // Bloquear cualquier otra colección
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
